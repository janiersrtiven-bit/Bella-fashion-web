generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Produto {
  id            Int               @id @default(autoincrement())
  nome          String
  slug          String?
  imagem        String
  preco         String
  precoCentavos Int?
  destaque      String
  descricao     String
  status        String
  categoria     String
  estoque       Int
  dataCadastro  String?
  horaCadastro  String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @default(now()) @updatedAt
  pedidos       Pedido[]
  imagens       ProdutoImagem[]
  variantes     ProdutoVariante[]
  pedidoItens   PedidoItem[]

  @@index([slug])
}

model ProdutoImagem {
  id        Int      @id @default(autoincrement())
  produtoId Int
  url       String
  alt       String?
  ordem     Int      @default(0)
  createdAt DateTime @default(now())
  produto   Produto  @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  @@index([produtoId, ordem])
}

model ProdutoVariante {
  id        Int      @id @default(autoincrement())
  produtoId Int
  tamanho   String
  cor       String
  sku       String?  @unique
  estoque   Int      @default(0)
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  produto   Produto  @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  pedidoItens PedidoItem[]

  @@unique([produtoId, tamanho, cor])
  @@index([produtoId, ativo])
}

model Pedido {
  id              Int     @id @default(autoincrement())
  cliente         String
  whatsapp        String
  emailCliente    String?
  enderecoEntrega String?
  produtoId       Int
  produtoNome     String
  quantidade      Int
  valorTotal      String
  metodoPagamento String
  statusPagamento String
  statusPedido    String
  codigoRastreio  String?
  statusEntrega   String
  observacoes     String?
  dataPedido      String
  horaPedido      String
  numeroPublico    String?
  subtotalCentavos Int?
  freteCentavos    Int      @default(0)
  totalCentavos    Int?
  estoqueReservado Boolean  @default(false)
  stripeSessionId  String?
  stripePaymentIntentId String?
  expiresAt        DateTime?
  clienteId        Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now()) @updatedAt
  produto          Produto @relation(fields: [produtoId], references: [id])
  clienteConta     Cliente? @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  itens            PedidoItem[]

  @@index([numeroPublico])
  @@index([clienteId, createdAt])
}

model PedidoItem {
  id                    Int              @id @default(autoincrement())
  pedidoId              Int
  produtoId             Int?
  varianteId            Int?
  nome                  String
  sku                   String?
  tamanho               String?
  cor                   String?
  quantidade            Int
  precoUnitarioCentavos Int
  totalCentavos         Int
  createdAt             DateTime         @default(now())
  pedido                Pedido           @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  produto               Produto?         @relation(fields: [produtoId], references: [id], onDelete: SetNull)
  variante              ProdutoVariante? @relation(fields: [varianteId], references: [id], onDelete: SetNull)

  @@index([pedidoId])
  @@index([produtoId])
}

model Cliente {
  id           Int               @id @default(autoincrement())
  nome         String
  email        String            @unique
  whatsapp     String
  passwordHash String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  pedidos      Pedido[]
  enderecos    EnderecoCliente[]
  sessoes      ClienteSessao[]
}

model EnderecoCliente {
  id        Int      @id @default(autoincrement())
  clienteId Int
  rotulo    String   @default("Principal")
  endereco  String
  principal Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cliente   Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([clienteId])
}

model ClienteSessao {
  id        Int      @id @default(autoincrement())
  clienteId Int
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  cliente   Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([clienteId])
  @@index([expiresAt])
}

model ConfiguracaoSite {
  id                 Int      @id @default(autoincrement())
  singleton          String   @unique @default("default")
  heroImagem         String?
  heroTitulo         String?
  heroSubtitulo      String?
  heroMaterial       String?
  heroPrecoDestaque  String?
  heroWhatsappTexto  String?
  heroWhatsappNumero String?
  avisoTopo          String?
  instagramUrl       String?
  emailContato       String?
  whatsappContato    String?
  sobreTexto         String?
  enviosTexto        String?
  trocasTexto        String?
  privacidadeTexto   String?
  termosTexto        String?
  instrucoesPix      String?
  freteFixoCentavos  Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}
