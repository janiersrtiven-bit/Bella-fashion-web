generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Produto {
  id            Int               @id @default(autoincrement())
  nome          String
  slug          String?
  imagem        String
  preco         String
  precoCentavos Int?
  destaque      String
  descricao     String
  status        String
  categoria     String
  estoque       Int
  dataCadastro  String?
  horaCadastro  String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @default(now()) @updatedAt
  pedidos       Pedido[]
  imagens       ProdutoImagem[]
  variantes     ProdutoVariante[]

  @@index([slug])
}

model ProdutoImagem {
  id        Int      @id @default(autoincrement())
  produtoId Int
  url       String
  alt       String?
  ordem     Int      @default(0)
  createdAt DateTime @default(now())
  produto   Produto  @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  @@index([produtoId, ordem])
}

model ProdutoVariante {
  id        Int      @id @default(autoincrement())
  produtoId Int
  tamanho   String
  cor       String
  sku       String?  @unique
  estoque   Int      @default(0)
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  produto   Produto  @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  @@unique([produtoId, tamanho, cor])
  @@index([produtoId, ativo])
}

model Pedido {
  id              Int     @id @default(autoincrement())
  cliente         String
  whatsapp        String
  emailCliente    String?
  enderecoEntrega String?
  produtoId       Int
  produtoNome     String
  quantidade      Int
  valorTotal      String
  metodoPagamento String
  statusPagamento String
  statusPedido    String
  codigoRastreio  String?
  statusEntrega   String
  observacoes     String?
  dataPedido      String
  horaPedido      String
  produto         Produto @relation(fields: [produtoId], references: [id])
}

model ConfiguracaoSite {
  id                 Int      @id @default(autoincrement())
  singleton          String   @unique @default("default")
  heroImagem         String?
  heroTitulo         String?
  heroSubtitulo      String?
  heroMaterial       String?
  heroPrecoDestaque  String?
  heroWhatsappTexto  String?
  heroWhatsappNumero String?
  avisoTopo          String?
  instagramUrl       String?
  emailContato       String?
  whatsappContato    String?
  sobreTexto         String?
  enviosTexto        String?
  trocasTexto        String?
  privacidadeTexto   String?
  termosTexto        String?
  instrucoesPix      String?
  freteFixoCentavos  Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}
